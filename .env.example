# =============================================================================
# Wispoke API — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# =============================================================================

# --- Required: Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# --- Required: JWT ---
JWT_SECRET_KEY=generate-a-64-char-hex-secret-with-openssl-rand-hex-32

# --- Required: Pinecone (vector store) ---
PINECONE_API_KEY=your-pinecone-api-key

# --- Required: Cohere (embeddings) ---
COHERE_API_KEY=your-cohere-api-key

# --- Required: At least one LLM provider ---
GROQ_API_KEY=your-groq-api-key
# OPENAI_API_KEY=your-openai-api-key

# --- Optional: Google OAuth ---
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# --- Optional: LemonSqueezy (payments) ---
# LEMONSQUEEZY_API_KEY=your-lemonsqueezy-api-key
# LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-signing-secret
# LEMONSQUEEZY_STORE_ID=your-store-id
# LEMONSQUEEZY_VARIANT_ID=your-pro-plan-variant-id
# ADMIN_DASHBOARD_URL=https://your-admin-dashboard.vercel.app

# --- Optional: App settings ---
# EMBEDDING_MODEL=embed-english-v3.0
# BASE_DOMAIN=mysite.com
# CHATBOT_PROTOCOL=https
# USE_SUBDOMAIN_ROUTING=true

# --- Voice agent (Twilio + Whisper + Piper + Groq) ---
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# VOICE_ENCRYPTION_KEY=

# Public base URL of this API as reachable from Twilio (used for webhook + stream URLs).
# Example: https://api.yourapp.com — must be https so Twilio accepts wss://.
# PUBLIC_API_BASE_URL=https://api.example.com

# Whisper STT sidecar (expects POST /transcribe with raw PCM16 mono 16kHz audio,
# returns {"text": "..."}). E.g. a faster-whisper server.
# WHISPER_STT_URL=http://whisper:9000

# Piper TTS sidecar (expects POST /tts {"text": "...", "voice": "en_US-amy-medium"},
# returns audio/wav PCM16 mono 22050Hz).
# PIPER_TTS_URL=http://piper:5000

# Validate incoming Twilio webhook signatures. Set to "false" only in local dev.
# TWILIO_VALIDATE_SIGNATURE=true
